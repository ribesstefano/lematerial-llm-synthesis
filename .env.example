# Copy to .env and fill in. Load .env before importing (e.g. load_dotenv() at app start).

# Direct APIs (used by DSPy/LiteLLM for synthesis extraction and judge)
ANTHROPIC_API_KEY=your_api_key_no_quotes   # Claude (claude-sonnet-4.5, extended thinking)
GEMINI_API_KEY=your_api_key_no_quotes      # Gemini (gemini-3-flash, thinking_level)
OPENAI_API_KEY=your_api_key_no_quotes      # if using OpenAI models
MISTRAL_API_KEY=your_api_key_no_quotes     # if using Mistral models or Mistral OCR

# OpenRouter (separate keys per model if desired; else set all to the same key)
OPENROUTER_QWEN_API_KEY=your_api_key_no_quotes      # qwen3.5-35b-a3b
OPENROUTER_KIMI_API_KEY=your_api_key_no_quotes      # moonshotai/kimi-k2.5
OPENROUTER_DEEPSEEK_API_KEY=your_api_key_no_quotes  # deepseek/deepseek-v3.2